# Java backend master key — required, server-side only (never prefix with NEXT_PUBLIC_)
JAVA_MASTER_KEY=

# Public site URLs
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_DOMAIN=
NEXT_PUBLIC_ENVIRONMENT=dev

# Comma-separated list of origins allowed by CORS in middleware.ts
# Example: https://example.com,https://www.example.com
ALLOWED_ORIGINS=

# Firebase web app config (from Firebase Console → Project settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Analytics tag used in the site-wide gtag.js snippet (optional — omit to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Exchange widget — Solana / Orbis manual swap
NEXT_PUBLIC_RPC_URL=                    # Helius or custom RPC endpoint (falls back to public clusterApiUrl if omitted)
NEXT_PUBLIC_SOLANA_NETWORK=mainnet       # devnet | mainnet-beta | testnet — must match the RPC URL above
NEXT_PUBLIC_ADMIN_WALLET=               # Admin Solana wallet public key (shown to clients)
NEXT_PUBLIC_ORBIS_MINT=                 # Orbis SPL token mint address
NEXT_PUBLIC_ORBIS_DECIMALS=6            # Orbis token decimal places (default 6)
NEXT_PUBLIC_ORBIS_RATE=12.5             # Orbis tokens per 1 SOL (admin-set display rate)
NEXT_PUBLIC_PROGRAM_ID=x2HARL2kBx2jVHtgWvf8sX8zbZ3sBAvtHJeg8AgosqR