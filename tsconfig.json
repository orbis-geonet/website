{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@public/*" : ["./public/*"],
      "@components" : ["./src/lib/components"],
      "@sections" : ["./src/lib/sections"],
      "@constants" : ["./src/lib/ts/constants"],
      "@interface" : ["./src/lib/ts/interface"],
      "@utils" : ["./src/lib/utils"],
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/lib/components/Reusables/spinner.component.tsx"],
  "exclude": ["node_modules"]
}
